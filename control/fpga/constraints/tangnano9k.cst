// ============================================================================
// Tang Nano 9K (GW1NR-9C) — Pin Constraint File
// VIGIL-RQ Quadruped PWM Controller
//
// Reference: Sipeed Tang Nano 9K schematic + pinout diagram
// https://wiki.sipeed.com/hardware/en/tang/Tang-Nano-9K/Nano-9K.html
// ============================================================================

// ── System Clock: 27 MHz on-board oscillator ──
IO_LOC  "clk_27m"    52;
IO_PORT "clk_27m"    IO_TYPE=LVCMOS33;

// ── Reset Button: S1 (active low) ──
// Pin 3 is on Bank 3 (VCCIO = 1.8V) → must use LVCMOS18
IO_LOC  "btn_rst_n"  3;
IO_PORT "btn_rst_n"  IO_TYPE=LVCMOS18;

// ── SPI Interface (from Raspberry Pi 4B) ──
// Choose header pins that are easy to wire. Using left-side header.
IO_LOC  "spi_sclk"   25;
IO_PORT "spi_sclk"   IO_TYPE=LVCMOS33;

IO_LOC  "spi_mosi"   26;
IO_PORT "spi_mosi"   IO_TYPE=LVCMOS33;

IO_LOC  "spi_cs_n"   27;
IO_PORT "spi_cs_n"   IO_TYPE=LVCMOS33 PULL_MODE=UP;

// ── 12× PWM Outputs ──
// Mapped to available GPIO header pins on Tang Nano 9K.
// These connect to 3.3V→5V level shifters before reaching DS3218 servos.
//
// Channel mapping:
//   [0]  FL Hip       [1]  FL Thigh     [2]  FL Knee
//   [3]  FR Hip       [4]  FR Thigh     [5]  FR Knee
//   [6]  RL Hip       [7]  RL Thigh     [8]  RL Knee
//   [9]  RR Hip       [10] RR Thigh     [11] RR Knee

IO_LOC  "pwm_out[0]"   28;
IO_PORT "pwm_out[0]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[1]"   29;
IO_PORT "pwm_out[1]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[2]"   30;
IO_PORT "pwm_out[2]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[3]"   31;
IO_PORT "pwm_out[3]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[4]"   32;
IO_PORT "pwm_out[4]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[5]"   33;
IO_PORT "pwm_out[5]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[6]"   34;
IO_PORT "pwm_out[6]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[7]"   35;
IO_PORT "pwm_out[7]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[8]"   40;
IO_PORT "pwm_out[8]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[9]"   41;
IO_PORT "pwm_out[9]"   IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[10]"  42;
IO_PORT "pwm_out[10]"  IO_TYPE=LVCMOS33 DRIVE=8;

IO_LOC  "pwm_out[11]"  48;
IO_PORT "pwm_out[11]"  IO_TYPE=LVCMOS33 DRIVE=8;

// ── On-board LEDs (active low) ──
// Pins 10-16 are on Bank 3 (VCCIO = 1.8V) → must use LVCMOS18
IO_LOC  "led[0]"  10;
IO_PORT "led[0]"  IO_TYPE=LVCMOS18;

IO_LOC  "led[1]"  11;
IO_PORT "led[1]"  IO_TYPE=LVCMOS18;

IO_LOC  "led[2]"  13;
IO_PORT "led[2]"  IO_TYPE=LVCMOS18;

IO_LOC  "led[3]"  14;
IO_PORT "led[3]"  IO_TYPE=LVCMOS18;

IO_LOC  "led[4]"  15;
IO_PORT "led[4]"  IO_TYPE=LVCMOS18;

IO_LOC  "led[5]"  16;
IO_PORT "led[5]"  IO_TYPE=LVCMOS18;
